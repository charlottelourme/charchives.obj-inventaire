# ── Base de données MongoDB Atlas ────────────────────────────────────────────
# Remplace <user>, <password>, <cluster> par tes valeurs Atlas
# Format : mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Laisse vide pour utiliser les fichiers JSON locaux (mode dev offline)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=charchives

# ── Cloudinary (hébergement photos cloud) ────────────────────────────────────
# Sans Cloudinary, les photos sont stockées en local dans /uploads (dev seulement)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── IA Vision (analyse photo automatique) ────────────────────────────────────
# Ordre de priorité : OpenRouter → Gemini → OpenAI
# Au moins une clé suffit. La cascade essaie automatiquement les suivants si l'un échoue.

# OPTION 1 — OpenRouter (GRATUIT) : modèles Llama/Qwen Vision open-source
# Inscription : https://openrouter.ai  →  "Keys" → créer une clé
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OPTION 2 — Gemini Google (GRATUIT, 1500 req/jour)
# Clé fraîche = quota remis à zéro : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OPTION 3 — OpenAI GPT-4o-mini (payant, ~$0.001/image, très fiable)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=3737

# ── CORS : origines autorisées (séparées par virgule, * = tout autoriser) ────
# En dev : laisser vide (accepte tout)
# En prod : CORS_ORIGIN=https://charchives.onrender.com
CORS_ORIGIN=
